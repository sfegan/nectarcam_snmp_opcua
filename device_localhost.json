{
    "host":          "127.0.0.1",
    "port":          1161,
    "community":     "public",
    "description":   "Local test SNMP agent (net-snmp on localhost)",
    "opcua_path":    "Localhost",
    "poll_interval": 10,
    "oids": [
        {
            "oid":         "SNMPv2-MIB::sysDescr.0",
            "opcua_name":  "sysDescr",
            "opcua_type":  "String",
            "description": "System description",
            "poll_every":  12
        },
        {
            "oid":         "SNMPv2-MIB::sysUpTime.0",
            "opcua_name":  "sysUpTime",
            "opcua_type":  "String",
            "description": "System uptime",
            "lifetime":    60
        },
        {
            "oid":         "SNMPv2-MIB::sysName.0",
            "opcua_name":  "sysName",
            "opcua_type":  "String",
            "description": "Administratively assigned system name",
            "poll_every":  12
        },
        {
            "oid":         "SNMPv2-MIB::sysLocation.0",
            "opcua_name":  "sysLocation",
            "opcua_type":  "String",
            "description": "Physical location of the system",
            "poll_every":  12
        }
    ]
}
